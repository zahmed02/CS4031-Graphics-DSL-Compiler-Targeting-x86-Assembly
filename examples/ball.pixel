x = 5
y = 5
dx = 1
dy = 1
loop 200 times
    clear_screen
    draw_pixel x, y, 1
    x = x + dx
    y = y + dy
    if x > 30 then
        dx = -1
    end
    if x < 1 then
        dx = 1
    end
    if y > 20 then
        dy = -1
    end
    if y < 1 then
        dy = 1
    end
    delay 20
end
wait_key